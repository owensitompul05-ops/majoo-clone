{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.4",
            "config": {
                "maxDuration": 10,
                "phpVersion": "8.3"
            }
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "build": {
        "env": {
            "COMPOSER_NODE_VERSION": "20"
        }
    }
}